{
  "schemaVersion": 1,
  "harnessVersion": "4.8.4",
  "source": {
    "repo": "https://github.com/DietrichGebert/ponytail",
    "ref": "v4.8.4"
  },
  "philosophy": "match-effort-to-the-cost-of-being-wrong",
  "secrets": {
    "envFile": ".env",
    "exampleFile": ".env.example",
    "keys": [
      "ANTHROPIC_API_KEY"
    ]
  },
  "decisions": [
    {
      "id": "tier1.markdown-rules",
      "enabled": true
    },
    {
      "id": "tier1.skills",
      "enabled": true
    },
    {
      "id": "tier1.commands",
      "enabled": true
    },
    {
      "id": "tier1.host-adapters",
      "enabled": true,
      "hosts": [
        "agents",
        "cline",
        "cursor",
        "gemini",
        "github-copilot",
        "kiro",
        "opencode",
        "windsurf"
      ]
    }
  ]
}

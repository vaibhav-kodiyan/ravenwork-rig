{
  "PreInvocation": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "node \"./hooks/rig-antigravity-pre-invocation.js\"",
          "timeout": 5
        }
      ]
    }
  ],
  "PreToolUse": [
    {
      "matcher": ".*",
      "hooks": [
        {
          "type": "command",
          "command": "node \"./hooks/rig-antigravity-tool.js\"",
          "timeout": 5
        }
      ]
    }
  ],
  "PostToolUse": [
    {
      "matcher": ".*",
      "hooks": [
        {
          "type": "command",
          "command": "node \"./hooks/rig-antigravity-tool.js\"",
          "timeout": 5
        }
      ]
    }
  ]
}
